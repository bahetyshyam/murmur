{
  "name": "murmur",
  "version": "2.0.0-dev",
  "description": "Tap-to-talk dictation for your desktop, powered by OpenAI transcription.",
  "author": "Shyam Bahety",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "gen:tray": "node scripts/gen-tray-icon.mjs",
    "build:native": "node-gyp rebuild --directory=native --arch=arm64 --target=$(node -p \"require('electron/package.json').version\") --dist-url=https://electronjs.org/headers && electron-rebuild -f -w better-sqlite3",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "npm run build:native && electron-vite build && electron-builder --mac --dir",
    "launch": "release/mac-arm64/Murmur.app/Contents/MacOS/Murmur",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "node-addon-api": "^8.8.0",
    "node-gyp": "^12.3.0",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
