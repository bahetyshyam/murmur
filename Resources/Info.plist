         lives in the maintainer's login keychain / the SPARKLE_ED_PRIVATE_KEY
         CI secret. Automatic checks + silent background install are enabled by
         default and mirrored by the "Automatically check for updates" toggle
         in Settings (config.autoCheckUpdates). -->
    <key>SUFeedURL</key>
    <string>https://github.com/bahetyshyam/murmur/releases/latest/download/appcast.xml</string>
    <key>SUPublicEDKey</key>
    <string>MRK1kqEbNK6JMiJmwHTVVtTRBqm/drl/I/uFVD+k/nw=</string>
    <key>SUEnableAutomaticChecks</key>
    <true/>
    <key>SUAutomaticallyUpdate</key>
